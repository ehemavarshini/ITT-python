class Solution:
    def merge(self, nums1, m, nums2, n):
        # Start pointers from the end of the actual data
        p1 = m - 1
        p2 = n - 1
        # Start pointer for the end of the total space in nums1
        p = m + n - 1

        while p2 >= 0:
            # If nums1 still has elements and they are larger than nums2
            if p1 >= 0 and nums1[p1] > nums2[p2]:
                nums1[p] = nums1[p1]
                p1 -= 1
            else:
                # Otherwise, move the element from nums2
                nums1[p] = nums2[p2]
                p2 -= 1
            p -= 1
